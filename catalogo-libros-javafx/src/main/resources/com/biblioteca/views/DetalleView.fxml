<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.biblioteca.controller.DetalleController"
      spacing="10">

    <!-- titulo -->
    <VBox alignment="CENTER">
        <padding>
            <Insets top="10" bottom="10"/>
        </padding>

        <Label text="detalle del libro"/>
    </VBox>

    <!-- datos -->
    <VBox VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="10" right="20" bottom="10" left="20"/>
        </padding>

        <GridPane hgap="10" vgap="10">

            <!-- isbn -->
            <Label text="isbn:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="lblIsbn" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <!-- titulo -->
            <Label text="titulo:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="lblTitulo" GridPane.columnIndex="1" GridPane.rowIndex="1" wrapText="true"/>

            <!-- autor -->
            <Label text="autor:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label fx:id="lblAutor" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <!-- anio -->
            <Label text="año:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label fx:id="lblAnio" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <!-- genero -->
            <Label text="genero:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <Label fx:id="lblGenero" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <!-- estado -->
            <Label text="estado:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <Label fx:id="lblDisponible" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <columnConstraints>
                <ColumnConstraints minWidth="80"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

        </GridPane>
    </VBox>

    <HBox alignment="CENTER">
        <padding>
            <Insets bottom="10"/>
        </padding>

        <Button fx:id="btnRegresar" text="regresar" onAction="#onRegresar"/>
    </HBox>

</VBox>