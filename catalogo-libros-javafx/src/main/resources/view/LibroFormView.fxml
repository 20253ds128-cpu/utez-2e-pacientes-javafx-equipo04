<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.utez.catalogolibros.controller.LibroFormController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <padding>
            <Insets top="20.0" />
         </padding>
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Formulario de Libro" VBox.vgrow="ALWAYS" />
            <TextField fx:id="txtIsbn" promptText="ISBN" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </TextField>
            <TextField fx:id="txtTitulo" promptText="Título" VBox.vgrow="ALWAYS" />
            <TextField fx:id="txtAutor" promptText="Autor" VBox.vgrow="ALWAYS" />
            <TextField fx:id="txtAnio" promptText="Año" VBox.vgrow="ALWAYS" />
            <TextField fx:id="txtGenero" promptText="Género" VBox.vgrow="ALWAYS" />
            <CheckBox fx:id="chkDisponible" mnemonicParsing="false" text="Disponible" />
            <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#onGuardar" text="Guardar" />
                  <Button fx:id="btnCancelar" mnemonicParsing="false" text="Cancelar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
