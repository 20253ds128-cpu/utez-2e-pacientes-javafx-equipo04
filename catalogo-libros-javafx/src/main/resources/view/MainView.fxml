<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.utez.catalogolibros.controller.MainController">
   <children>
      <VBox layoutX="93.0" layoutY="46.0" prefHeight="300.0" prefWidth="400.0" spacing="10.0">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Catálogo de Libros" />
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button fx:id="btnNuevo" mnemonicParsing="false" onAction="#onNuevo" text="Nuevo" />
                  <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#onEditar" text="Editar" />
                  <Button fx:id="btnEliminar" mnemonicParsing="false" text="Eliminar" />
                  <Button fx:id="btnDetalle" mnemonicParsing="false" text="Ver Detalle" />
                  <Button fx:id="btnExportar" mnemonicParsing="false" text="Exportar" />
               </children>
            </HBox>
            <TableView fx:id="tablaLibros" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="colIsbn" prefWidth="54.0" text="ISBN" />
                <TableColumn fx:id="colTitulo" prefWidth="61.0" text="Título" />
                  <TableColumn fx:id="colAutor" prefWidth="61.0" text="Autor" />
                  <TableColumn fx:id="colAnio" prefWidth="65.0" text="Año" />
                  <TableColumn fx:id="colGenero" prefWidth="67.0" text="Género" />
                  <TableColumn fx:id="colDisponible" prefWidth="70.0" text="Disponible" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>

</AnchorPane>
